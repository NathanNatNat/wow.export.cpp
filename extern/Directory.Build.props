<Project>
  <!-- Prevent Visual Studio from picking up stray .vcxproj/.csproj files in submodules. -->
  <PropertyGroup>
    <BuildProjectReferences>false</BuildProjectReferences>
    <ShouldUnsetParentConfigurationAndPlatform>false</ShouldUnsetParentConfigurationAndPlatform>
  </PropertyGroup>
  <Target Name="Build" />
  <Target Name="Clean" />
  <Target Name="Rebuild" />
</Project>
