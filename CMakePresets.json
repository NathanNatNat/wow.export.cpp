{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "windows-msvc-debug",
            "displayName": "Windows MSVC — Debug",
            "description": "Windows x64, MSVC, Debug (default)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "cl",
                "CMAKE_CXX_COMPILER": "cl"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "architecture": {
                "value": "x64",
                "strategy": "external"
            }
        },
        {
            "name": "windows-msvc-release",
            "displayName": "Windows MSVC — Release",
            "description": "Windows x64, MSVC, Release",
            "inherits": "windows-msvc-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "windows-msvc-relwithdebinfo",
            "displayName": "Windows MSVC — RelWithDebInfo",
            "description": "Windows x64, MSVC, RelWithDebInfo",
            "inherits": "windows-msvc-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "linux-gcc-debug",
            "displayName": "Linux GCC — Debug",
            "description": "Linux x64, GCC, Debug (default)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++",
                "CMAKE_C_FLAGS": "-m64",
                "CMAKE_CXX_FLAGS": "-m64"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "architecture": {
                "value": "x64",
                "strategy": "external"
            }
        },
        {
            "name": "linux-gcc-release",
            "displayName": "Linux GCC — Release",
            "description": "Linux x64, GCC, Release",
            "inherits": "linux-gcc-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "linux-gcc-relwithdebinfo",
            "displayName": "Linux GCC — RelWithDebInfo",
            "description": "Linux x64, GCC, RelWithDebInfo",
            "inherits": "linux-gcc-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "windows-debug",
            "displayName": "Debug",
            "configurePreset": "windows-msvc-debug"
        },
        {
            "name": "windows-release",
            "displayName": "Release",
            "configurePreset": "windows-msvc-release"
        },
        {
            "name": "windows-relwithdebinfo",
            "displayName": "RelWithDebInfo",
            "configurePreset": "windows-msvc-relwithdebinfo"
        },
        {
            "name": "linux-debug",
            "displayName": "Debug",
            "configurePreset": "linux-gcc-debug"
        },
        {
            "name": "linux-release",
            "displayName": "Release",
            "configurePreset": "linux-gcc-release"
        },
        {
            "name": "linux-relwithdebinfo",
            "displayName": "RelWithDebInfo",
            "configurePreset": "linux-gcc-relwithdebinfo"
        }
    ]
}
